---

<style>
    .nav-theme-toggle {
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .nav-theme-toggle > a {
        cursor: pointer;
    }

    .nav-theme-toggle .icon {
        width: 24px;
        height: 24px;
        margin-right: 8px;
    }

    .theme-toggle-icon {
        /* font-size: 1.2rem;
        color: var(--text-primary);
        transition: opacity 0.3s ease; */
    }
</style>

<div class="nav-theme-toggle">
    <a
        id="theme-toggle-btn"
        aria-label="Toggle dark/light theme"
        title="Toggle theme"
        aria-pressed="false"
    >
        <svg
            id="theme-icon-sun"
            class="icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            style="display:none"
        >
            <use href="#icon-light-mode"></use>
        </svg>
        <svg
            id="theme-icon-moon"
            class="icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            style="display:none"
        >
            <use href="#icon-dark-mode"></use>
        </svg>
    </a>
</div>
