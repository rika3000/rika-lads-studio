---
import photoGalleryJson from "../data/photo_gallery_test.json";
import PhotoCard from "./PhotoCard.astro";
import { formatDate } from "../utils/helper";

const thumbnailList = Object.values(photoGalleryJson.images).map(
    (image, index) => {
        return {
            index: index,
            src: `/images/photos/${image.name}.webp`,
            dateMonthYearString: formatDate(image.date),
            ...image,
        };
    },
);
// get unique characters
const characters = [
    ...new Set(thumbnailList.flatMap((image) => image.characters)),
];
---

<div id="photo-gallery-container">
    <!-- FILTER SECTION -->
    <section id="filter-section">
        <!-- Filter content will go here -->
        <div class="filter-header">
            <h2>FILTER</h2>
            <button class="filter-clear" aria-label="clear filter">
                <span>RESET ALL</span>
            </button>
        </div>
        <div class="filter-content">
            <div class="filter-category">
                <h3>CHARACTERS</h3>
                <!-- Filter content will go here -->
            </div>
            <div class="filter-category">
                <h3>PHOTO MODES</h3>
                <!-- Filter content will go here -->
            </div>
            <div class="filter-category">
                <h3>TAGS</h3>
                <!-- Filter content will go here -->
            </div>
        </div>
    </section>

    <!-- TOTAL PHOTO COUNT -->
    <div class="total">
        {photoGalleryJson.images.length} PHOTO{
            photoGalleryJson.images.length !== 1 ? "S" : ""
        }
    </div>
    <!-- PHOTO GALLERY SECTION -->
    <section id="photo-gallery-section">
        <div class="grid">
            {
                thumbnailList.map((thumbnail) => (
                    <PhotoCard
                        index={thumbnail.index}
                        name={thumbnail.name}
                        date={thumbnail.dateMonthYearString}
                        characterList={thumbnail.characters}
                        tags={thumbnail.tags}
                        qrPostUrl={thumbnail.qrPostUrl}
                    />
                ))
            }
        </div>
        <!-- <div class="empty-state" id="empty-state">
            <div class="empty-state-icon">✦</div>
            <p>No images match the selected filters.</p>
        </div>-->
    </section>
    <!-- photoData should be updated based on its index when a PhotoCard is clicked -->
    <script></script>
</div>
