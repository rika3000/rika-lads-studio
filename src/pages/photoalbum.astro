---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PHOTO_ALBUM_TITLE } from "../lib/constants";
import PhotoGallery from "../components/PhotoGallery.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout pageTitle={PHOTO_ALBUM_TITLE} />
<div class="body-wrapper">
	<section class="hero">
		<p class="hero-eyebrow">LOVE AND DEEPSPACE</p>
		<h1 class="hero-title"><em>Rika's</em> Photo Album</h1>
		<p class="hero-sub">Okay, here's a confession:</p>
	</section>
	<PhotoGallery />
	<Footer />
</div>
